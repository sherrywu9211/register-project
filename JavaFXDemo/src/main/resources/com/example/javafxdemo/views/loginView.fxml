<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<HBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.javafxdemo.controllers.LoginController"
      stylesheets="@../styles/login.css">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
  </padding>

  <Label text="帳號"/>
  <TextField fx:id="userNameField" promptText="請輸入帳號" styleClass="userNameField" prefWidth="20"/>
  <Label text="密碼"/>
  <PasswordField fx:id="passwordField" promptText="請輸入密碼" styleClass="passwordField" prefWidth="20"/>

  <Label fx:id="loginButton"/>
  <Button text="登入" onAction="#onHelloButtonClick"/>

</HBox>
